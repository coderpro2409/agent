# Default browser LLM mode. No AI environment variables are needed on Vercel.
# SmolLM2 runs in the visitor's browser; local rules remain as a fallback.
OPEN_MODEL_PROVIDER=local

# Optional open-source model backend. Uncomment only if you later get a key.
# Example: Groq + Llama 3.1 8B.
#
# Use any OpenAI-compatible chat completions endpoint that serves an open model,
# for example a self-hosted vLLM/Ollama server, Together, Groq, OpenRouter, etc.
# OPEN_MODEL_PROVIDER=groq
# OPEN_MODEL_NAME=llama-3.1-8b-instant
# GROQ_API_KEY=

# Advanced/custom provider settings.
OPEN_MODEL_URL=
OPEN_MODEL_API_KEY=
OPEN_MODEL_ALLOW_NO_AUTH=false
OPEN_MODEL_TIMEOUT_MS=20000

# Gmail IMAP defaults. Usually do not change these for Gmail.
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993
