# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored, so your secrets stay local.

# Gmail address the agent will read from.
EMAIL_ADDRESS=you@gmail.com

# Gmail App Password (NOT your normal password).
# Create one at: https://myaccount.google.com/apppasswords
# Requires 2-Step Verification to be enabled on the account.
APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Hugging Face token for the open-source LLM (replaces local Ollama).
# Get a free token at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# --- Optional overrides ---

# IMAP server + port. Defaults work for Gmail.
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993

# Open-weight model id served by the HF Inference API.
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
